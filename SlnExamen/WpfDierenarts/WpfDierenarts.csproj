  <ItemGroup>
    <ProjectReference Include="..\CLDierenarts\CLDierenarts.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="Database\Dierenartsen.db">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Database\DierenartsenDB.sql">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <Resource Include="Images\hond.png" />

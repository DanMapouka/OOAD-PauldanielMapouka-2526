    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <UseWPF>true</UseWPF>
    <RootNamespace>WpfDierenarts</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
